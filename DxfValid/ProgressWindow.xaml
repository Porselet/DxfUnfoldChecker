<Window
    x:Class="DxfValid.ProgressWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:DxfValid"
    mc:Ignorable="d"
    Title="Синхронизация комплекта"
    Height="150"
    Width="400"
    ResizeMode="NoResize">
    <Grid>
        <TextBlock
            x:Name="TxtStatus"
            Text="Подготовка к сканированию..."
            Margin="20,20,20,0"
            VerticalAlignment="Top"
            FontSize="12" />
        <ProgressBar
            x:Name="PBar"
            Minimum="0"
            Value="0"
            Height="20"
            Margin="20,69,20,0"
            VerticalAlignment="Top" />
        <TextBlock
            x:Name="TxtPercent"
            Text="0%"
            Margin="0,94,20,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Foreground="Gray" />
    </Grid>
</Window>

<Window
    x:Class="DxfValid.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="DxfUnfoldChecker - Диспетчер комплекта разверток"
    Height="550"
    Width="900"
    WindowStartupLocation="CenterScreen"
    ContentRendered="Window_ContentRendered">
    <Grid
        Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition
                Height="Auto" />
            <RowDefinition
                Height="*" />
            <RowDefinition
                Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Верхняя панель управления -->
        <StackPanel
            Grid.Row="0"
            Orientation="Horizontal"
            Margin="0,0,0,15">
            <Button
                x:Name="BtnSelectFolder"
                Content="📁 Проверить"
                Width="150"
                Height="40"
                Margin="0,0,15,0"
                Click="BtnSelectFolder_Click" />

            <TextBlock
                x:Name="TxtFolderPath"
                Text="Папка не выбрана..."
                VerticalAlignment="Center" />
        </StackPanel>
        
        <!-- Таблица всего комплекта -->
        <GroupBox
            Grid.Row="1"
            Header="Список файлов в комплекте (Двойной клик для детального просмотра и графики)">
            <DataGrid
                x:Name="DgFolderSummary"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                GridLinesVisibility="Horizontal"
                Background="White"
                FontSize="12"
                MouseDoubleClick="DgFolderSummary_MouseDoubleClick">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem
                            Header="📁 Открыть папки с выделением файлов (Smart Sync)"
                            Click="MenuOpenFolderSmart_Click"
                            FontWeight="Bold" />
                    </ContextMenu>
                </DataGrid.ContextMenu>

                <DataGrid.Columns>

                    <DataGridTextColumn
                        Header="Имя файла развертки"
                        Binding="{Binding FileName}"
                        Width="220"
                        FontWeight="SemiBold" />

                    <DataGridTextColumn
                        Header="Версия DXF"
                        Binding="{Binding DxfVersion}"
                        Width="150" />
                    <DataGridTextColumn
                        Header="Статус"
                        Binding="{Binding Status}"
                        Width="90" />
                    <DataGridTextColumn
                        Header="Инженерный вердикт валидатора"
                        Binding="{Binding SummaryMessage}"
                        Width="*" />
                </DataGrid.Columns>

            </DataGrid>
        </GroupBox>

        <!-- Нижний статус-бар -->
        <TextBlock
            x:Name="TxtBatchStatusBar"
            Grid.Row="2"
            Text="Готово. Отчет генерируется автоматически в целевую папку."
            Margin="0,10,0,0"
            Foreground="DimGray"
            FontSize="11" />
    </Grid>
</Window>
